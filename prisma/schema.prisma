generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== AUTH (Auth.js / NextAuth PrismaAdapter) ==================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ================== RBAC ==================

model Role {
  id   String @id @default(cuid())
  name String @unique

  permissions Permission[]
  userRoles   UserRole[]
}

model Permission {
  id     String @id @default(cuid())
  roleId String
  module String
  action String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

// ================== NGHIEP VU TASKFLOW ==================

model Project {
  id         String    @id @default(cuid())
  name       String
  status     String?
  startDate  DateTime?
  endDate    DateTime?
  value      Float?
  customerId String?
  centerId   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  center   Center?   @relation(fields: [centerId], references: [id])
  tasks    Task[]
  reports  Report[]
  plans    TestPlan[]
  quotes   Quote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String?
  priority    String?
  assigneeId  String?
  projectId   String?
  dueDate     DateTime?

  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id         String   @id @default(cuid())
  name       String
  code       String?
  role       String?
  gender     String?
  team       String?
  accessRole String?
  email      String?  @unique
  phone      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id        String   @id @default(cuid())
  title     String
  content   String?
  projectId String?

  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

model Center {
  id      String  @id @default(cuid())
  name    String
  address String?
  manager String?
  phone   String?
  notes   String?

  equipment         Equipment[]
  equipmentBookings EquipmentBooking[]
  projects          Project[]
}

model Equipment {
  id           String    @id @default(cuid())
  name         String
  code         String?   @unique
  category     String?
  manufacturer String?
  model        String?
  qty          Int?
  status       String?
  room         String?
  area         Float?
  power        Float?
  spec         String?
  calLast      DateTime?
  calInterval  Int?
  calCert      String?
  calVendor    String?
  centerId     String?
  hourlyRate   Float?

  center   Center?            @relation(fields: [centerId], references: [id])
  bookings EquipmentBooking[]
}

model EquipmentBooking {
  id          String   @id @default(cuid())
  equipmentId String
  centerId    String?
  startTime   DateTime
  endTime     DateTime
  bookedBy    String?

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  center    Center?   @relation(fields: [centerId], references: [id])
}

model Customer {
  id      String  @id @default(cuid())
  name    String
  contact String?
  email   String?
  phone   String?
  address String?
  value   Float?
  notes   String?

  quotes   Quote[]
  projects Project[]
  samples  Sample[]
}

model Quote {
  id          String  @id @default(cuid())
  customerId  String?
  projectId   String?
  title       String
  code        String?
  quoteDate   DateTime?
  vatPercent  Float?    @default(10)
  creator     String?
  notes       String?
  status      String?
  totalAmount Float?

  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  catalogItems      QuoteCatalogItem[]
  matrixItems       QuoteMatrixItem[]
  personnelItems    QuotePersonnelItem[]
  depreciationItems QuoteDepreciationItem[]
  variableItems     QuoteVariableItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteCatalogItem {
  id         String @id @default(cuid())
  quoteId    String
  name       String
  standard   String?
  price      Float?
  quantity   Int?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteMatrixItem {
  id      String @id @default(cuid())
  quoteId String
  label   String
  value   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuotePersonnelItem {
  id      String @id @default(cuid())
  quoteId String
  role    String
  rate    Float?
  hours   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteDepreciationItem {
  id        String @id @default(cuid())
  quoteId   String
  assetName String
  rate      Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteVariableItem {
  id      String  @id @default(cuid())
  quoteId String
  key     String
  value   String?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// --- Bảng giá gốc (master data) dùng chung cho mọi báo giá ---
// Tương ứng các trang cấu hình: Danh mục bài thử (quote-catalog),
// Đơn giá nhân sự (quote-personnel), Khấu hao thiết bị (quote-depreciation),
// Chi phí biến đổi khác (quote-variable). Khi lập báo giá, người dùng chọn
// từ các bảng gốc này để thêm vào Quote*Item tương ứng.
model TestCatalogItem {
  id         String  @id @default(cuid())
  code       String?
  name       String
  standard   String?
  sampleQty  String?
  leadTime   String?
  price      Float?

  createdAt DateTime @default(now())
}

model PersonnelRateConfig {
  id          String @id @default("singleton")
  techRate    Float  @default(0)
  engRate     Float  @default(0)
  leadRate    Float  @default(0)
  mgrRate     Float  @default(0)
  overheadPct Float  @default(0)
}

model PersonnelRouting {
  id          String @id @default(cuid())
  testCode    String?
  testName    String
  prepHours   String?
  setupHours  String?
  testHours   String?
  reportHours String?

  createdAt DateTime @default(now())
}

model DepreciationAsset {
  id          String @id @default(cuid())
  assetName   String
  assetGroup  String?
  totalValue  Float?
  years       Float?

  createdAt DateTime @default(now())
}

model VariableCost {
  id          String @id @default(cuid())
  costType    String
  description String?
  amount      Float?

  createdAt DateTime @default(now())
}

model AuditPlan {
  id          String    @id @default(cuid())
  title       String
  scheduledAt DateTime?
  status      String?

  logs   AuditLog[]
  phases AuditPhase[]
  items  AuditItem[]
}

model AuditLog {
  id          String   @id @default(cuid())
  auditPlanId String?
  note        String?
  createdAt   DateTime @default(now())

  auditPlan AuditPlan? @relation(fields: [auditPlanId], references: [id])
}

model AuditPhase {
  id          String @id @default(cuid())
  auditPlanId String
  name        String
  order       Int?

  auditPlan AuditPlan   @relation(fields: [auditPlanId], references: [id], onDelete: Cascade)
  items     AuditItem[]
}

model AuditItem {
  id          String    @id @default(cuid())
  auditPlanId String
  phaseId     String?
  name        String
  assignee    String?
  planStart   DateTime?
  planEnd     DateTime?
  actualStart DateTime?
  actualEnd   DateTime?
  status      String?
  note        String?

  auditPlan AuditPlan   @relation(fields: [auditPlanId], references: [id], onDelete: Cascade)
  phase     AuditPhase? @relation(fields: [phaseId], references: [id])
}

model PurchaseItem {
  id       String  @id @default(cuid())
  name     String
  quantity Int?
  cost     Float?
  status   String?
  note     String?
}

// ================== SAMPLES (LIMS) ==================

model Sample {
  id         String    @id @default(cuid())
  code       String?
  name       String
  customerId String?
  status     String? // received | testing | done
  receivedAt DateTime?

  customer  Customer?   @relation(fields: [customerId], references: [id])
  testItems TestItem[]

  createdAt DateTime @default(now())
}

// ================== TEST PLAN ==================

model TestPlan {
  id        String  @id @default(cuid())
  projectId String
  title     String?

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   TestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestItem {
  id          String    @id @default(cuid())
  testPlanId  String
  sampleId    String?
  name        String
  priority    String?
  standard    String?
  assignee    String?
  planStart   DateTime?
  planEnd     DateTime?
  actualStart DateTime?
  actualEnd   DateTime?
  result      String? // pass | fail | pending
  progress    Int?
  note        String?

  testPlan TestPlan @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  sample   Sample?  @relation(fields: [sampleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================== QUALITY (ISO 17025) ==================

model QualityChecklistItem {
  id      String   @id @default(cuid())
  name    String
  done    Boolean  @default(false)
  dueDate DateTime?
}

model QualityAuditEntry {
  id        String   @id @default(cuid())
  entity    String?
  actor     String?
  role      String?
  area      String?
  action    String?
  note      String?
  createdAt DateTime @default(now())
}
