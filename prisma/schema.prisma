generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== AUTH (Auth.js / NextAuth PrismaAdapter) ==================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Additive (thiết kế 6 cấp bậc + phân vùng theo Trung tâm/Nhóm vận hành): đồng bộ
  // 1-chiều từ Member cùng email (xem syncUserRoleForMember trong features/members/actions.ts)
  // — dùng để tính getScopeFilter() ngay trong session, không phải query lại Member mỗi request.
  centerId     String?
  groupId      String?
  isOperations Boolean @default(false)
  allCenters   Boolean @default(false)

  center Center? @relation(fields: [centerId], references: [id])
  group  Group?  @relation(fields: [groupId], references: [id])

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]
  viewerCenterAccess ViewerCenterAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ================== RBAC ==================

model Role {
  id   String @id @default(cuid())
  name String @unique

  permissions Permission[]
  userRoles   UserRole[]
}

model Permission {
  id     String @id @default(cuid())
  roleId String
  module String
  action String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

// ================== NGHIEP VU TASKFLOW ==================

model Project {
  id         String    @id @default(cuid())
  name       String
  status     String?
  startDate  DateTime?
  endDate    DateTime?
  value      Float?
  customerId String?
  centerId   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  center   Center?   @relation(fields: [centerId], references: [id])
  tasks      Task[]
  reportRows ReportRow[]
  plans      TestPlan[]
  quotes   Quote[]
  samples  Sample[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String?
  priority    String?
  assigneeId  String?
  projectId   String?
  dueDate     DateTime?
  // Additive (phân vùng theo Trung tâm/Nhóm) — stamp khi tạo mới theo center/group của
  // người tạo, dùng để lọc hiển thị theo getScopeFilter(). Lưu riêng để lọc được cả Task
  // không gắn Project.
  centerId    String?
  groupId     String?

  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id         String   @id @default(cuid())
  name       String
  code       String?
  role       String?
  gender     String?
  team       String? // legacy, giữ để tương thích dữ liệu cũ — không dùng để phân quyền nữa
  accessRole String?
  email      String?  @unique
  phone      String?

  // Additive (thiết kế 6 cấp bậc + phân vùng Trung tâm/Nhóm): centerId/groupId xác định
  // phạm vi dữ liệu thành viên được thấy; isOperations=true bỏ qua phân vùng Trung tâm cho
  // các module vận hành ngang (Equipment/Booking/Khấu hao/Chi phí biến đổi/Quality/AuditPlan).
  centerId     String?
  groupId      String?
  isOperations Boolean @default(false)
  allCenters   Boolean @default(false)

  center Center? @relation(fields: [centerId], references: [id])
  group  Group?  @relation(fields: [groupId], references: [id])

  testItems TestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Viết lại theo bản gốc (renderReports/openReport/drawEdit, dòng 5433-5443 taskflow_original.html):
// trang Report KHONG co model title/content tu do - moi du an co 1 bang bao cao thu nghiem
// voi 6 cot CO DINH (khong phai cot tu dinh nghia - checklist truoc day ghi nham "cot tu dinh nghia", da sua lai cho dung voi COLS ban goc).
model ReportRow {
  id          String   @id @default(cuid())
  projectId   String
  position    Int      @default(0)
  testName    String?
  standard    String?
  steps       String?
  criteria    String?
  equipment   String?
  calibration String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Center {
  id        String  @id @default(cuid())
  name      String
  address   String?
  manager   String?
  phone     String?
  notes     String?
  // Dùng cho tính chi phí điện/nhà xưởng trong Quote Matrix (ported từ qtMachineElec/qtMachineNX).
  elecPrice Float?
  rentPrice Float?

  equipment         Equipment[]
  equipmentBookings EquipmentBooking[]
  projects          Project[]
  // Additive (thiết kế 6 cấp bậc + phân vùng Trung tâm/Nhóm):
  groups             Group[]
  members            Member[]
  users              User[]
  viewerCenterAccess ViewerCenterAccess[]
}

// Additive — Nhóm (Group) nằm trong 1 Trung tâm, do Trưởng nhóm (team_lead) quản lý.
// Dùng để gán thành viên (Kỹ sư/KTV) vào 1 nhóm cụ thể trong Trung tâm.
model Group {
  id         String  @id @default(cuid())
  name       String
  centerId   String
  teamLeadId String?

  center  Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  members Member[]
  users   User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Additive — cấp quyền xem (đọc, không chỉnh sửa) cho Người xem (viewer) vào các Trung
// tâm cụ thể ngoài phạm vi mặc định (mặc định viewer không thấy Trung tâm nào).
model ViewerCenterAccess {
  id       String @id @default(cuid())
  userId   String
  centerId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, centerId])
}

model Equipment {
  id           String    @id @default(cuid())
  name         String
  code         String?   @unique
  category     String?
  manufacturer String?
  model        String?
  qty          Int?
  status       String?
  room         String?
  area         Float?
  power        Float?
  spec         String?
  calLast      DateTime?
  calInterval  Int?
  calCert      String?
  calVendor    String?
  centerId     String?
  hourlyRate   Float?

  center    Center?            @relation(fields: [centerId], references: [id])
  testItems TestItem[]
  bookings EquipmentBooking[]
}

model EquipmentBooking {
  id          String   @id @default(cuid())
  equipmentId String
  centerId    String?
  startTime   DateTime
  endTime     DateTime
  bookedBy    String?
  department  String?
  purpose     String?

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  center    Center?   @relation(fields: [centerId], references: [id])

  createdAt DateTime @default(now())
}

model Customer {
  id      String  @id @default(cuid())
  name    String
  contact String?
  email   String?
  phone   String?
  address String?
  value   Float?
  notes   String?

  quotes   Quote[]
  projects Project[]
  samples  Sample[]
}

model Quote {
  id          String  @id @default(cuid())
  customerId  String?
  projectId   String?
  title       String
  code        String?
  quoteDate   DateTime?
  vatPercent  Float?    @default(10)
  creator     String?
  notes       String?
  status      String?
  totalAmount Float?

  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  catalogItems      QuoteCatalogItem[]
  matrixItems       QuoteMatrixItem[]
  personnelItems    QuotePersonnelItem[]
  depreciationItems QuoteDepreciationItem[]
  variableItems     QuoteVariableItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteCatalogItem {
  id         String @id @default(cuid())
  quoteId    String
  name       String
  standard   String?
  price      Float?
  quantity   Int?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteMatrixItem {
  id      String @id @default(cuid())
  quoteId String
  label   String
  value   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuotePersonnelItem {
  id      String @id @default(cuid())
  quoteId String
  role    String
  rate    Float?
  hours   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteDepreciationItem {
  id        String @id @default(cuid())
  quoteId   String
  assetName String
  rate      Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteVariableItem {
  id      String  @id @default(cuid())
  quoteId String
  key     String
  value   String?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// --- Bảng giá gốc (master data) dùng chung cho mọi báo giá ---
// Tương ứng các trang cấu hình: Danh mục bài thử (quote-catalog),
// Đơn giá nhân sự (quote-personnel), Khấu hao thiết bị (quote-depreciation),
// Chi phí biến đổi khác (quote-variable). Khi lập báo giá, người dùng chọn
// từ các bảng gốc này để thêm vào Quote*Item tương ứng.
model TestCatalogItem {
  id         String  @id @default(cuid())
  code       String?
  name       String
  standard   String?
  sampleQty  String?
  leadTime   String?
  price      Float?
  // Additive — chỉ để gắn thẻ/hiển thị theo Trung tâm (Tầng 2, xem thiết kế mục 12), KHÔNG
  // dùng để chặn quyền xem/ghi — để trống = "Chung toàn lab".
  centerId   String?

  createdAt DateTime @default(now())
}

model PersonnelRateConfig {
  id          String @id @default("singleton")
  techRate    Float  @default(0)
  engRate     Float  @default(0)
  leadRate    Float  @default(0)
  mgrRate     Float  @default(0)
  overheadPct Float  @default(0)
  // Additive — gắn thẻ hiển thị theo Trung tâm (display-only, xem thiết kế mục 12).
  centerId    String?
}

model PersonnelRouting {
  id          String @id @default(cuid())
  testCode    String?
  testName    String
  prepHours   String?
  setupHours  String?
  testHours   String?
  reportHours String?
  // Additive — gắn thẻ hiển thị theo Trung tâm (display-only, xem thiết kế mục 12).
  centerId    String?

  createdAt DateTime @default(now())
}

model DepreciationAsset {
  id          String @id @default(cuid())
  assetName   String
  assetGroup  String?
  totalValue  Float?
  years       Float?
  // Additive — gắn thẻ hiển thị theo Trung tâm (display-only, xem thiết kế mục 12).
  centerId    String?

  createdAt DateTime @default(now())
}

model VariableCost {
  id          String @id @default(cuid())
  costType    String
  description String?
  amount      Float?
  // Additive — gắn thẻ hiển thị theo Trung tâm (display-only, xem thiết kế mục 12).
  centerId    String?

  createdAt DateTime @default(now())
}

model AuditPlan {
  id          String    @id @default(cuid())
  title       String
  scheduledAt DateTime?
  status      String?
  // Additive — nullable: kế hoạch có thể áp dụng riêng 1 Trung tâm (lọc theo
  // getScopeFilter) hoặc để trống = áp dụng toàn lab (Operations/Director luôn thấy hết).
  centerId    String?
  groupId     String?

  logs   AuditLog[]
  phases AuditPhase[]
  items  AuditItem[]
}

model AuditLog {
  id          String   @id @default(cuid())
  auditPlanId String?
  note        String?
  createdAt   DateTime @default(now())

  // Additive fields (rà soát lần 16) — nhật ký hành động người dùng chung toàn hệ thống,
  // port từ hàm logAudit(entity, action, target, detail) trong bản gốc.
  entity   String?
  action   String?
  target   String?
  detail   String?
  userId   String?
  userName String?
  // Additive (module Quality, rà soát lần 17) — vai trò của người thực hiện tại
  // thời điểm ghi log, port từ trường a.role trong bản gốc (ql-audit-body hiển thị
  // cột riêng cho vai trò, không gộp vào detail).
  role     String?

  auditPlan AuditPlan? @relation(fields: [auditPlanId], references: [id])
}

model AuditPhase {
  id          String @id @default(cuid())
  auditPlanId String
  name        String
  order       Int?

  auditPlan AuditPlan   @relation(fields: [auditPlanId], references: [id], onDelete: Cascade)
  items     AuditItem[]
}

model AuditItem {
  id          String    @id @default(cuid())
  auditPlanId String
  phaseId     String?
  name        String
  assignee    String?
  planStart   DateTime?
  planEnd     DateTime?
  actualStart DateTime?
  actualEnd   DateTime?
  status      String?
  note        String?

  auditPlan AuditPlan   @relation(fields: [auditPlanId], references: [id], onDelete: Cascade)
  phase     AuditPhase? @relation(fields: [phaseId], references: [id])
}

model PurchaseItem {
  id        String  @id @default(cuid())
  name      String
  quantity  Int?
  cost      Float?
  status    String?
  note      String?

  // Ported from the original app's purchaseItems fields (openPmForm / renderPurchase,
  // 19-column detail table). amount/price kept as free-text like the original (formatted
  // Vietnamese currency strings such as "120.000.000"), not Float, to match source behavior.
  amount    String? // Giá trị (VNĐ)
  price     String? // Đơn giá
  supplier  String? // Nhà cung cấp
  task      String? // Loại task
  tfs       String?
  jira      String?
  pr        String? // Mã PR
  po        String? // Mã PO
  migo      String?
  tinhtrang String? // Tình trạng chi tiết (textarea)
  pic       String? // Phòng mua hàng (nhóm ngoài lab)
  owner     String? // Người phụ trách (tên thành viên)
  lab       String? // Trung tâm
  tfslink   String? // Liên kết TFS

  // Additive (phân vùng theo Trung tâm/Nhóm) — trường thật dùng để lọc quyền xem/ghi,
  // khác với "lab" (text tự do, chỉ hiển thị/gộp nhóm như bản gốc).
  centerId  String?
  groupId   String?
}

// ================== SAMPLES (LIMS) ==================

model Sample {
  id              String    @id @default(cuid())
  code            String?
  name            String
  serialNumber    String?
  qty             Int?      @default(1)
  storageLocation String?
  customerId      String?
  projectId       String?
  sampleGrade     String?
  group           String?
  status          String? // received | testing | completed | returned (empty = auto)
  receivedAt      DateTime?
  // Additive (phân vùng theo Trung tâm/Nhóm) — stamp khi tạo mới, dùng để lọc theo getScopeFilter().
  centerId        String?
  groupId         String?

  customer  Customer?   @relation(fields: [customerId], references: [id])
  project   Project?    @relation(fields: [projectId], references: [id])
  testItems TestItem[]

  createdAt DateTime @default(now())
}

// ================== TEST PLAN ==================

model TestPlan {
  id        String  @id @default(cuid())
  projectId String
  title     String?

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   TestItem[]
  packs   TestPack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestPack {
  id         String  @id @default(cuid())
  testPlanId String
  code       String
  serial     String?
  qty        Int?    @default(1)

  testPlan TestPlan   @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  items    TestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestItem {
  id          String    @id @default(cuid())
  testPlanId  String
  packId      String?
  sampleId    String?
  reportCode  String?
  equipmentId String?
  name        String
  priority    String?
  standard    String?
  assignee    String?
  picId       String?
  planStart   DateTime?
  planEnd     DateTime?
  actualStart DateTime?
  actualEnd   DateTime?
  result      String? // pass | fail | delay | queuing | ongoing | cancel
  progress    Int?
  note        String?

  testPlan  TestPlan   @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  pack      TestPack?  @relation(fields: [packId], references: [id])
  sample    Sample?    @relation(fields: [sampleId], references: [id])
  equipment Equipment? @relation(fields: [equipmentId], references: [id])
  pic       Member?    @relation(fields: [picId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================== QUALITY (ISO 17025) ==================

// Thay thế QualityChecklistItem/QualityAuditEntry (rà soát lần 17) — bản gốc không
// có "tạo hạng mục checklist tự do" hay "tạo nhật ký kiểm toán tay" trong trang Quality.
// renderQuality() dùng QL_CHECKLIST_GROUPS cố định (17 hạng mục theo mục 4/5/6/7/8 ISO
// 17025) — 1 số hạng mục tự tính từ dữ liệu thật (qlChecklistAutoState), còn lại là
// checkbox tay lưu localStorage (tf_ql_checklist_v1). Model dưới đây chỉ lưu trạng thái
// tay theo từng key cố định đó. Nhật ký kiểm toán (audit trail) trong trang Quality là
// VIEW CHỈ ĐỌC trên bảng AuditLog chung toàn hệ thống (do logAudit() ở các module khác
// ghi vào) — không có form tạo/xoá nhật ký riêng trong trang Quality của bản gốc.
model QualityChecklistState {
  id      String  @id @default(cuid())
  key     String  @unique
  checked Boolean @default(false)
}
