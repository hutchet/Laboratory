generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== AUTH (Auth.js / NextAuth PrismaAdapter) ==================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ================== RBAC (Buoc 3) ==================

model Role {
  id   String @id @default(cuid())
  name String @unique // admin | manager | technician | quote_staff | viewer

  permissions Permission[]
  userRoles   UserRole[]
}

model Permission {
  id     String @id @default(cuid())
  roleId String
  module String // "tasks" | "equipment" | "quotes" | "settings" | "*" (tat ca)...
  action String // "view" | "create" | "edit" | "delete"

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

// ================== NGHIEP VU TASKFLOW ==================
// TODO Buoc 5: viet script import du lieu tu localStorage export cua ban HTML goc vao cac bang duoi day.

model Project {
  id        String    @id @default(cuid())
  name      String
  status    String?
  startDate DateTime?
  endDate   DateTime?
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String?
  assigneeId  String?
  projectId   String?
  dueDate     DateTime?

  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id    String  @id @default(cuid())
  name  String
  role  String?
  email String? @unique
  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id        String   @id @default(cuid())
  title     String
  content   String?
  createdAt DateTime @default(now())
}

model Center {
  id      String  @id @default(cuid())
  name    String
  address String?

  equipment         Equipment[]
  equipmentBookings EquipmentBooking[]
}

model Equipment {
  id       String  @id @default(cuid())
  name     String
  code     String? @unique
  centerId String?

  center   Center?            @relation(fields: [centerId], references: [id])
  bookings EquipmentBooking[]
}

model EquipmentBooking {
  id          String   @id @default(cuid())
  equipmentId String
  centerId    String?
  startTime   DateTime
  endTime     DateTime
  bookedBy    String?

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  center    Center?   @relation(fields: [centerId], references: [id])
}

model Customer {
  id      String  @id @default(cuid())
  name    String
  email   String?
  phone   String?
  address String?

  quotes Quote[]
}

model Quote {
  id          String  @id @default(cuid())
  customerId  String?
  title       String
  status      String?
  totalAmount Float?

  customer Customer? @relation(fields: [customerId], references: [id])

  catalogItems      QuoteCatalogItem[]
  matrixItems       QuoteMatrixItem[]
  personnelItems    QuotePersonnelItem[]
  depreciationItems QuoteDepreciationItem[]
  variableItems     QuoteVariableItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteCatalogItem {
  id       String @id @default(cuid())
  quoteId  String
  name     String
  price    Float?
  quantity Int?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteMatrixItem {
  id      String @id @default(cuid())
  quoteId String
  label   String
  value   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuotePersonnelItem {
  id      String @id @default(cuid())
  quoteId String
  role    String
  rate    Float?
  hours   Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteDepreciationItem {
  id        String @id @default(cuid())
  quoteId   String
  assetName String
  rate      Float?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteVariableItem {
  id      String  @id @default(cuid())
  quoteId String
  key     String
  value   String?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model AuditPlan {
  id          String    @id @default(cuid())
  title       String
  scheduledAt DateTime?
  status      String?

  logs AuditLog[]
}

model AuditLog {
  id          String   @id @default(cuid())
  auditPlanId String?
  note        String?
  createdAt   DateTime @default(now())

  auditPlan AuditPlan? @relation(fields: [auditPlanId], references: [id])
}

model PurchaseItem {
  id       String @id @default(cuid())
  name     String
  quantity Int?
  cost     Float?
}
